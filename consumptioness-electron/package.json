{
  "name": "consumptioness",
  "version": "0.0.1",
  "description": "PC Power Consumption Calculator with TNB Malaysia Tariff",
  "author": "Haz",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "systeminformation": "^5.23.0",
    "recharts": "^2.15.0",
    "lucide-react": "^0.469.0",
    "jspdf": "^2.5.2",
    "exceljs": "^4.4.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.haz.consumptioness",
    "productName": "Consumptioness",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "HazProject",
      "repo": "Consumptioness"
    }
  }
}
